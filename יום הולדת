<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Happy Birthday Chaya Aliza</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;1,400&family=Quicksand:wght@500;600;700&display=swap');

  :root {
    --pink1: #f9c6d0;
    --pink2: #f4a0b5;
    --pink3: #e8728f;
    --pink4: #fce4ec;
    --cream: #fdf6f0;
    --text: #b5607a;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    background: var(--cream);
    font-family: 'Quicksand', sans-serif;
    min-height: 100vh;
    overflow-x: hidden;
  }

  body::before {
    content: '';
    position: fixed; inset: 0;
    background:
      radial-gradient(ellipse at 10% 20%, rgba(249,198,208,0.35) 0%, transparent 55%),
      radial-gradient(ellipse at 90% 80%, rgba(244,160,181,0.25) 0%, transparent 55%);
    pointer-events: none; z-index: 0;
  }

  #confetti { position: fixed; inset: 0; pointer-events: none; z-index: 0; }

  /* HERO */
  .hero {
    position: relative; z-index: 1;
    text-align: center; padding: 56px 20px 20px;
  }

  .banner-row {
    display: flex; justify-content: center;
    gap: 5px; margin-bottom: 6px; flex-wrap: wrap;
  }

  .bl {
    width: 40px; height: 40px;
    background: linear-gradient(135deg, var(--pink2), var(--pink3));
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    color: white; font-weight: 700; font-size: 0.95rem;
    box-shadow: 0 3px 10px rgba(232,114,143,0.3);
    animation: bounce-in 0.5s cubic-bezier(0.175,0.885,0.32,1.275) both;
  }

  .r1 .bl:nth-child(1){animation-delay:.05s} .r1 .bl:nth-child(2){animation-delay:.1s}
  .r1 .bl:nth-child(3){animation-delay:.15s} .r1 .bl:nth-child(4){animation-delay:.2s}
  .r1 .bl:nth-child(5){animation-delay:.25s}
  .r2 .bl:nth-child(1){animation-delay:.3s} .r2 .bl:nth-child(2){animation-delay:.35s}
  .r2 .bl:nth-child(3){animation-delay:.4s} .r2 .bl:nth-child(4){animation-delay:.45s}
  .r2 .bl:nth-child(5){animation-delay:.5s} .r2 .bl:nth-child(6){animation-delay:.55s}
  .r2 .bl:nth-child(7){animation-delay:.6s} .r2 .bl:nth-child(8){animation-delay:.65s}

  @keyframes bounce-in {
    0%   { transform: scale(0) translateY(16px); opacity: 0; }
    100% { transform: scale(1) translateY(0); opacity: 1; }
  }

  .name {
    font-family: 'Playfair Display', serif;
    font-size: clamp(3rem, 11vw, 6rem);
    color: var(--pink3);
    text-shadow: 3px 3px 0 #fce4ec;
    animation: pop-in 0.9s cubic-bezier(0.175,0.885,0.32,1.275) 0.8s both;
    line-height: 1; margin-top: 16px;
  }

  .subtitle {
    font-size: 0.78rem; color: var(--pink2);
    font-weight: 700; letter-spacing: 5px;
    text-transform: uppercase; margin-top: 10px;
    animation: fade-up 1s ease 1.2s both;
  }

  @keyframes pop-in {
    0% { transform: scale(0.4) rotate(-5deg); opacity: 0; }
    100% { transform: scale(1) rotate(0); opacity: 1; }
  }
  @keyframes fade-up {
    from { opacity:0; transform:translateY(10px); }
    to   { opacity:1; transform:translateY(0); }
  }

  /* MESSAGE */
  .message-wrap {
    position: relative; z-index: 1;
    max-width: 520px; margin: 32px auto 36px; padding: 0 20px;
    animation: fade-up 0.8s ease 1s both;
  }

  .message-card {
    background: white; border-radius: 22px;
    padding: 28px 30px;
    border: 2px solid var(--pink1);
    box-shadow: 0 6px 28px rgba(244,160,181,0.18);
    position: relative;
  }

  .message-card::before {
    content: '';
    position: absolute; top: -1px; left: 50%;
    transform: translateX(-50%);
    width: 56px; height: 4px;
    background: linear-gradient(90deg, var(--pink2), var(--pink3));
    border-radius: 0 0 4px 4px;
  }

  .message-text {
    text-align: center; color: #a06070;
    font-size: 1rem; line-height: 1.95; font-weight: 600;
  }
  .message-text .hl { color: var(--pink3); font-weight: 700; }

  /* DIVIDER */
  .divider {
    position: relative; z-index: 1;
    text-align: center; margin: 4px 0 28px;
  }
  .divider span {
    display: inline-block; width: 70px; height: 1px;
    background: linear-gradient(90deg, transparent, var(--pink2), transparent);
    vertical-align: middle; margin: 0 10px;
  }
  .divider-dot {
    display: inline-block; width: 5px; height: 5px;
    border-radius: 50%; background: var(--pink2); vertical-align: middle;
  }

  /* PHOTO BOX */
  .photo-box-wrap {
    position: relative; z-index: 1;
    max-width: 600px; margin: 0 auto 16px; padding: 0 20px;
  }

  .photo-box {
    background: white; border-radius: 20px;
    padding: 32px 22px 24px;
    box-shadow: 0 2px 0 var(--pink1), 0 4px 0 var(--pink2), 0 8px 32px rgba(232,114,143,0.15);
    border: 2px solid var(--pink1); position: relative;
  }

  .photo-box-label {
    position: absolute; top: -13px; left: 22px;
    background: white; padding: 0 10px;
    font-family: 'Playfair Display', serif;
    font-style: italic; font-size: 0.88rem; color: var(--pink3);
  }

  /* POLAROIDS GRID */
  .polaroids {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 18px;
  }

  /* SINGLE POLAROID CARD */
  .polaroid {
    background: white;
    padding: 9px 9px 0;
    box-shadow: 0 6px 20px rgba(232,114,143,0.16), 0 1px 4px rgba(0,0,0,0.07);
    transition: transform 0.3s, box-shadow 0.3s;
    position: relative;
    animation: card-in 0.5s ease both;
    overflow: hidden;
  }

  .polaroid:nth-child(4n+1) { transform: rotate(-2deg); }
  .polaroid:nth-child(4n+2) { transform: rotate(1.8deg); }
  .polaroid:nth-child(4n+3) { transform: rotate(1.4deg); }
  .polaroid:nth-child(4n+4) { transform: rotate(-1.6deg); }
  .polaroid:hover { transform: rotate(0) scale(1.03) !important; box-shadow: 0 14px 36px rgba(232,114,143,0.28); z-index: 5; }

  .polaroid img {
    width: 100%; aspect-ratio: 1; object-fit: cover; display: block;
  }

  .tape {
    position: absolute; top: -9px; left: 50%;
    transform: translateX(-50%);
    width: 38px; height: 14px;
    background: rgba(249,198,208,0.6); border-radius: 2px;
  }

  /* MESSAGE STRIP inside polaroid */
  .msg-strip {
    padding: 8px 8px 10px;
    background: white;
  }

  .msg-strip .sender {
    font-family: 'Playfair Display', serif;
    font-style: italic; font-size: 0.72rem;
    color: var(--pink3); font-weight: 700;
    margin-bottom: 3px;
  }

  .msg-strip .letter {
    font-size: 0.72rem; color: #b08090;
    line-height: 1.5; font-weight: 600;
    word-break: break-word;
  }

  @keyframes card-in {
    from { opacity:0; transform: scale(0.85); }
    to   { opacity:1; }
  }

  /* ADD PHOTO SLOT */
  .add-slot {
    background: var(--pink4);
    padding: 9px 9px 10px;
    position: relative; cursor: pointer;
    border: 2px dashed var(--pink2);
    transition: transform 0.3s, box-shadow 0.3s;
    display: flex; flex-direction: column;
  }

  .add-slot:nth-child(4n+1) { transform: rotate(-1.5deg); }
  .add-slot:nth-child(4n+2) { transform: rotate(1.2deg); }
  .add-slot:nth-child(4n+3) { transform: rotate(1deg); }
  .add-slot:nth-child(4n+4) { transform: rotate(-1.2deg); }
  .add-slot:hover { transform: rotate(0) scale(1.04) !important; box-shadow: 0 10px 28px rgba(232,114,143,0.2); }

  .add-inner {
    aspect-ratio: 1;
    display: flex; flex-direction: column;
    align-items: center; justify-content: center; gap: 8px;
  }

  .add-icon {
    width: 38px; height: 38px; border-radius: 50%;
    background: linear-gradient(135deg, var(--pink2), var(--pink3));
    display: flex; align-items: center; justify-content: center;
    color: white; font-size: 1.3rem;
    box-shadow: 0 3px 10px rgba(232,114,143,0.3);
  }

  .add-text {
    font-size: 0.68rem; color: var(--pink3);
    font-weight: 700; letter-spacing: 2px;
    text-transform: uppercase; text-align: center;
  }

  .add-msg-strip {
    padding: 6px 6px 8px;
    font-size: 0.68rem; color: var(--pink2);
    font-style: italic; text-align: center;
    font-family: 'Playfair Display', serif;
  }

  /* ADD BUTTON */
  .add-btn-wrap {
    position: relative; z-index: 1;
    text-align: center; margin: 22px 0 48px;
  }

  .add-btn {
    display: inline-block; padding: 14px 40px;
    background: linear-gradient(135deg, var(--pink2), var(--pink3));
    color: white; font-family: 'Quicksand', sans-serif;
    font-weight: 700; font-size: 0.85rem;
    letter-spacing: 2px; text-transform: uppercase;
    border-radius: 50px; border: none; cursor: pointer;
    box-shadow: 0 6px 20px rgba(232,114,143,0.35);
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .add-btn:hover { transform: translateY(-2px); box-shadow: 0 10px 28px rgba(232,114,143,0.45); }

  /* MODAL */
  .modal-overlay {
    position: fixed; inset: 0;
    background: rgba(253,246,240,0.94);
    backdrop-filter: blur(10px);
    z-index: 100;
    display: flex; align-items: center; justify-content: center;
    opacity: 0; pointer-events: none; transition: opacity 0.3s;
    padding: 20px;
  }

  .modal-overlay.open { opacity: 1; pointer-events: all; }

  .modal {
    background: white; border-radius: 26px;
    padding: 34px 28px; max-width: 380px; width: 100%;
    border: 2px solid var(--pink1);
    box-shadow: 0 20px 60px rgba(232,114,143,0.2);
    text-align: center;
    transform: scale(0.9); transition: transform 0.3s;
    max-height: 90vh; overflow-y: auto;
  }

  .modal-overlay.open .modal { transform: scale(1); }

  .modal-title {
    font-family: 'Playfair Display', serif;
    font-size: 1.5rem; color: var(--pink3); margin-bottom: 4px;
  }

  .modal-sub {
    font-size: 0.75rem; color: var(--pink2);
    font-weight: 700; letter-spacing: 2px;
    text-transform: uppercase; margin-bottom: 22px;
  }

  .modal-upload {
    border: 2px dashed var(--pink2); border-radius: 16px;
    padding: 22px 16px; margin-bottom: 14px;
    cursor: pointer; transition: border-color 0.2s, background 0.2s;
    position: relative;
  }

  .modal-upload:hover { border-color: var(--pink3); background: var(--pink4); }
  .modal-upload input { position: absolute; inset: 0; opacity: 0; cursor: pointer; }
  .modal-upload-text { font-size: 0.85rem; color: var(--text); font-weight: 600; }
  .modal-upload-sub { font-size: 0.72rem; color: var(--pink2); margin-top: 3px; }

  #modal-preview {
    display: none; width: 100%; aspect-ratio: 1;
    object-fit: cover; border-radius: 12px; margin-bottom: 14px;
  }

  .modal-field {
    width: 100%; border: 2px solid var(--pink1);
    border-radius: 12px; padding: 10px 14px;
    font-family: 'Quicksand', sans-serif; font-weight: 600;
    font-size: 0.9rem; color: var(--text);
    outline: none; margin-bottom: 12px;
    transition: border-color 0.2s;
  }

  .modal-field:focus { border-color: var(--pink3); }
  .modal-field::placeholder { color: var(--pink1); }

  textarea.modal-field {
    resize: none; height: 90px;
    font-family: 'Playfair Display', serif;
    font-style: italic; font-size: 0.88rem; line-height: 1.6;
  }

  .word-count {
    font-size: 0.7rem; color: var(--pink2);
    text-align: right; margin-top: -8px; margin-bottom: 14px;
  }
  .word-count.over { color: #e8728f; font-weight: 700; }

  .modal-btns { display: flex; gap: 10px; }

  .modal-confirm {
    flex: 1; padding: 12px;
    background: linear-gradient(135deg, var(--pink2), var(--pink3));
    color: white; border: none; border-radius: 50px;
    font-family: 'Quicksand', sans-serif;
    font-weight: 700; font-size: 0.82rem;
    letter-spacing: 1px; cursor: pointer;
    box-shadow: 0 4px 14px rgba(232,114,143,0.3);
    transition: transform 0.2s;
  }

  .modal-confirm:hover { transform: translateY(-1px); }
  .modal-confirm:disabled { opacity: 0.4; cursor: not-allowed; transform: none; }

  .modal-cancel {
    padding: 12px 18px; background: none;
    border: 2px solid var(--pink1); border-radius: 50px;
    color: var(--pink2); font-family: 'Quicksand', sans-serif;
    font-weight: 700; font-size: 0.82rem; cursor: pointer;
    transition: border-color 0.2s;
  }

  .modal-cancel:hover { border-color: var(--pink3); }

  /* FOOTER */
  .footer {
    position: relative; z-index: 1;
    text-align: center; padding-bottom: 60px;
    color: var(--pink2); font-weight: 700;
    letter-spacing: 4px; font-size: 0.72rem; text-transform: uppercase;
  }

  .big-heart {
    display: block; font-size: 2.8rem;
    animation: beat 1s ease-in-out infinite;
    margin-bottom: 10px; color: var(--pink3);
  }

  @keyframes beat {
    0%,100% { transform: scale(1); }
    14%      { transform: scale(1.18); }
    28%      { transform: scale(1); }
    42%      { transform: scale(1.1); }
  }
</style>
</head>
<body>

<canvas id="confetti"></canvas>

<section class="hero">
  <div class="banner-row r1">
    <div class="bl">H</div><div class="bl">A</div><div class="bl">P</div><div class="bl">P</div><div class="bl">Y</div>
  </div>
  <div class="banner-row r2">
    <div class="bl">B</div><div class="bl">I</div><div class="bl">R</div><div class="bl">T</div>
    <div class="bl">H</div><div class="bl">D</div><div class="bl">A</div><div class="bl">Y</div>
  </div>
  <div class="name">Chaya Aliza</div>
  <div class="subtitle">Birthday Girl</div>
</section>

<div class="message-wrap">
  <div class="message-card">
    <p class="message-text">
      To our dearest <span class="hl">Chaya Aliza</span>,<br><br>
      You deserve all the love, all the joy, and all the magic in the world
      today and every single day. Thank you for being the most wonderful friend.
      We <span class="hl">love you so so much.</span><br><br>
      <span class="hl">Happy Birthday, beautiful girl.</span>
    </p>
  </div>
</div>

<div class="divider">
  <span></span><span class="divider-dot"></span><span></span>
</div>

<div class="photo-box-wrap">
  <div class="photo-box">
    <span class="photo-box-label">our memories</span>
    <div class="polaroids" id="grid"></div>
  </div>
</div>

<div class="add-btn-wrap">
  <button class="add-btn" id="openModal">Add your memory</button>
</div>

<div class="footer">
  <span class="big-heart">&#9825;</span>
  love you to the moon and back
</div>

<!-- MODAL -->
<div class="modal-overlay" id="modalOverlay">
  <div class="modal">
    <div class="modal-title">Add your memory</div>
    <div class="modal-sub">for Chaya Aliza</div>

    <div class="modal-upload" id="uploadZone">
      <input type="file" accept="image/*" id="fileInput">
      <div class="modal-upload-text">Tap to choose a photo</div>
      <div class="modal-upload-sub">one photo per person</div>
    </div>
    <img id="modal-preview" alt="preview">

    <input class="modal-field" type="text" id="nameInput" placeholder="Your name" maxlength="40">

    <textarea class="modal-field" id="msgInput" placeholder="Write a short message... (up to 50 words)"></textarea>
    <div class="word-count" id="wordCount">0 / 50 words</div>

    <div class="modal-btns">
      <button class="modal-cancel" id="closeModal">Cancel</button>
      <button class="modal-confirm" id="confirmAdd" disabled>Add memory</button>
    </div>
  </div>
</div>

<script>
const INITIAL = [{"src": "data:image/jpeg;base64,", "name": "Chaya", "msg": ""}, {"src": "data:image/jpeg;base64,", "name": "Chaya", "msg": ""}, {"src": "data:image/jpeg;base64,", "name": "Chaya", "msg": ""}, {"src": "data:image/jpeg;base64,", "name": "Chaya", "msg": ""}];

let photos = [];
let pendingImg = null;

function wordCount(str) {
  return str.trim() === '' ? 0 : str.trim().split(/\s+/).length;
}

function renderGrid() {
  const grid = document.getElementById('grid');
  grid.innerHTML = '';

  photos.forEach((p, i) => {
    const div = document.createElement('div');
    div.className = 'polaroid';
    div.style.animationDelay = (i * 0.08) + 's';
    div.innerHTML = `
      <div class="tape"></div>
      <img src="${p.src}" alt="memory">
      <div class="msg-strip">
        <div class="sender">${p.name || 'anonymous'}</div>
        ${p.msg ? `<div class="letter">${p.msg}</div>` : ''}
      </div>
    `;
    grid.appendChild(div);
  });

  // Add empty slots to fill up to next even number, min 2 extra
  const totalSlots = Math.max(photos.length + 2, 4);
  const slots = totalSlots - photos.length;
  for (let i = 0; i < slots; i++) {
    const div = document.createElement('div');
    div.className = 'add-slot';
    div.innerHTML = `
      <div class="add-inner">
        <div class="add-icon">+</div>
        <div class="add-text">Add photo</div>
      </div>
      <div class="add-msg-strip">your memory here</div>
    `;
    div.addEventListener('click', openModal);
    grid.appendChild(div);
  }

  // Save to localStorage
  try {
    const toSave = photos.map(p => ({src: p.src.substring(0,50)+'...', name: p.name, msg: p.msg}));
    localStorage.setItem('bday_photos_meta', JSON.stringify(toSave));
  } catch(e) {}
}

// Modal logic
const overlay = document.getElementById('modalOverlay');
const fileInput = document.getElementById('fileInput');
const preview = document.getElementById('modal-preview');
const nameInput = document.getElementById('nameInput');
const msgInput = document.getElementById('msgInput');
const wordCountEl = document.getElementById('wordCount');
const confirmBtn = document.getElementById('confirmAdd');

function openModal() {
  pendingImg = null;
  preview.style.display = 'none';
  preview.src = '';
  nameInput.value = '';
  msgInput.value = '';
  wordCountEl.textContent = '0 / 50 words';
  wordCountEl.className = 'word-count';
  confirmBtn.disabled = true;
  overlay.classList.add('open');
}

function closeModal() {
  overlay.classList.remove('open');
}

function validate() {
  const wc = wordCount(msgInput.value);
  wordCountEl.textContent = wc + ' / 50 words';
  wordCountEl.className = wc > 50 ? 'word-count over' : 'word-count';
  confirmBtn.disabled = !(pendingImg && nameInput.value.trim() && wc <= 50);
}

document.getElementById('openModal').addEventListener('click', openModal);
document.getElementById('closeModal').addEventListener('click', closeModal);
overlay.addEventListener('click', (e) => { if (e.target === overlay) closeModal(); });

fileInput.addEventListener('change', (e) => {
  const file = e.target.files[0];
  if (!file) return;
  const reader = new FileReader();
  reader.onload = (ev) => {
    pendingImg = ev.target.result;
    preview.src = pendingImg;
    preview.style.display = 'block';
    document.getElementById('uploadZone').style.display = 'none';
    validate();
  };
  reader.readAsDataURL(file);
});

nameInput.addEventListener('input', validate);
msgInput.addEventListener('input', validate);

document.getElementById('confirmAdd').addEventListener('click', () => {
  if (!pendingImg) return;
  photos.push({
    src: pendingImg,
    name: nameInput.value.trim(),
    msg: msgInput.value.trim()
  });
  renderGrid();
  closeModal();
  document.getElementById('uploadZone').style.display = 'block';
});

// Confetti
const canvas = document.getElementById('confetti');
const ctx = canvas.getContext('2d');
function resize() { canvas.width = window.innerWidth; canvas.height = window.innerHeight; }
resize(); window.addEventListener('resize', resize);

const colors = ['#f9c6d0','#f4a0b5','#e8728f','#fce4ec','#f8b4c8','#ffffff'];
const pieces = Array.from({length: 65}, () => ({
  x: Math.random() * window.innerWidth,
  y: Math.random() * window.innerHeight - window.innerHeight,
  size: 4 + Math.random() * 7,
  color: colors[Math.floor(Math.random() * colors.length)],
  speed: 0.7 + Math.random() * 1.6,
  angle: Math.random() * Math.PI * 2,
  spin: (Math.random() - 0.5) * 0.07,
  drift: (Math.random() - 0.5) * 0.5,
  shape: Math.random() > 0.5 ? 'circle' : 'rect',
}));

function draw() {
  ctx.clearRect(0, 0, canvas.width, canvas.height);
  pieces.forEach(p => {
    ctx.save();
    ctx.translate(p.x, p.y);
    ctx.rotate(p.angle);
    ctx.fillStyle = p.color;
    ctx.globalAlpha = 0.55;
    if (p.shape === 'circle') {
      ctx.beginPath();
      ctx.arc(0, 0, p.size/2, 0, Math.PI*2);
      ctx.fill();
    } else {
      ctx.fillRect(-p.size/2, -p.size/4, p.size, p.size/2);
    }
    ctx.restore();
    p.y += p.speed; p.x += p.drift; p.angle += p.spin;
    if (p.y > canvas.height) { p.y = -20; p.x = Math.random() * canvas.width; }
  });
  requestAnimationFrame(draw);
}
draw();

// Init
photos = INITIAL.map(p => ({...p}));
renderGrid();
</script>
</body>
</html>
